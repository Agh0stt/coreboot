CONFIG_BOARD_RAISIN_PICASSO=y
CONFIG_VENDOR_RAISIN=y

# ROM size
CONFIG_BOARD_ROMSIZE_KB_8192=y

# Payload - full UEFI via TianoCore EDK2
CONFIG_PAYLOAD_TIANOCORE=y
CONFIG_TIANOCORE_BOOT_MANAGER_ESCAPE=y
CONFIG_TIANOCORE_CBMEM_CONSOLE=y

# Legacy support via SeaBIOS chainloaded
CONFIG_TIANOCORE_CSM=y

# Boot splash
CONFIG_BOOTSPLASH_IMAGE=y
CONFIG_BOOTSPLASH_FILE="bootsplash.jpg"

# Console - UART0 for debug
CONFIG_AMD_SOC_CONSOLE_UART=y
CONFIG_CONSOLE_SERIAL=y
CONFIG_TTYS0_BAUD=115200

# ACPI
CONFIG_HAVE_ACPI_TABLES=y
CONFIG_HAVE_ACPI_RESUME=y

# SMBIOS
CONFIG_GENERATE_SMBIOS_TABLES=y
CONFIG_SMBIOS_MANUFACTURER="Raisin"
CONFIG_SMBIOS_PRODUCT_NAME="Raisin Picasso"

# No vboot for now
CONFIG_VBOOT=n
